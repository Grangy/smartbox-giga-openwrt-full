{
  "log": {
    "disabled": false,
    "level": "warn",
    "timestamp": false
  },
  "dns": {
    "servers": [
      {
        "type": "udp",
        "tag": "bootstrap-dns-server",
        "server": "77.88.8.8",
        "server_port": 53
      },
      {
        "type": "udp",
        "tag": "dns-server",
        "server": "8.8.8.8",
        "server_port": 53
      },
      {
        "type": "fakeip",
        "tag": "fakeip-server",
        "inet4_range": "198.18.0.0/15"
      }
    ],
    "rules": [
      {
        "action": "reject",
        "query_type": "HTTPS"
      },
      {
        "action": "reject",
        "domain_suffix": "use-application-dns.net"
      },
      {
        "action": "route",
        "server": "fakeip-server",
        "rewrite_ttl": 60,
        "domain": [
          "fakeip.podkop.fyi",
          "ip.podkop.fyi"
        ],
        "rule_set": [
          "main-russia_inside-community-ruleset",
          "main-user-domains-ruleset",
          "main-local-domains-ruleset",
          "main-external-domains-ruleset"
        ]
      }
    ],
    "final": "dns-server",
    "strategy": "ipv4_only",
    "independent_cache": true
  },
  "ntp": {},
  "certificate": {},
  "endpoints": [],
  "inbounds": [
    {
      "type": "tproxy",
      "tag": "tproxy-in",
      "listen": "127.0.0.1",
      "listen_port": 1602,
      "tcp_fast_open": true,
      "udp_fragment": true
    },
    {
      "type": "direct",
      "tag": "dns-in",
      "listen": "127.0.0.42",
      "listen_port": 53
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct-out"
    },
    {
      "type": "vless",
      "tag": "main-out",
      "server": "YOUR_VLESS_HOST",
      "server_port": 443,
      "uuid": "YOUR_UUID",
      "tls": {
        "enabled": true,
        "server_name": "github.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "YOUR_REALITY_PUBLIC_KEY",
          "short_id": "YOUR_SHORT_ID"
        }
      }
    },
    {
      "type": "socks",
      "tag": "byedpi-out",
      "server": "127.0.0.1",
      "server_port": 1080
    }
  ],
  "route": {
    "rules": [
      {
        "action": "sniff",
        "inbound": [
          "tproxy-in",
          "dns-in"
        ]
      },
      {
        "action": "hijack-dns",
        "protocol": "dns"
      },
      {
        "action": "route",
        "inbound": "tproxy-in",
        "outbound": "main-out",
        "domain": "ip.podkop.fyi"
      },
      {
        "action": "route",
        "inbound": "tproxy-in",
        "outbound": "main-out",
        "rule_set": [
          "main-telegram-ruleset"
        ]
      },
      {
        "action": "route",
        "inbound": "tproxy-in",
        "outbound": "main-out",
        "rule_set": [
          "main-tiktok-ruleset"
        ]
      },
      {
        "action": "route-options",
        "domain": "fakeip.podkop.fyi",
        "override_port": 8443
      },
      {
        "action": "route",
        "inbound": "tproxy-in",
        "outbound": "main-out",
        "rule_set": [
          "main-russia_inside-community-ruleset",
          "main-user-domains-ruleset",
          "main-local-domains-ruleset",
          "main-external-domains-ruleset"
        ]
      }
    ],
    "rule_set": [
      {
        "type": "remote",
        "tag": "main-russia_inside-community-ruleset",
        "format": "binary",
        "url": "https://github.com/itdoginfo/allow-domains/releases/latest/download/russia_inside.srs",
        "update_interval": "1d"
      },
      {
        "type": "local",
        "tag": "main-user-domains-ruleset",
        "format": "source",
        "path": "/tmp/sing-box/rulesets/main-user-domains-ruleset.json"
      },
      {
        "type": "local",
        "tag": "main-local-domains-ruleset",
        "format": "source",
        "path": "/tmp/sing-box/rulesets/main-local-domains-ruleset.json"
      },
      {
        "type": "local",
        "tag": "main-external-domains-ruleset",
        "format": "source",
        "path": "/tmp/sing-box/rulesets/main-external-domains-ruleset.json"
      },
      {
        "type": "local",
        "tag": "main-telegram-ruleset",
        "format": "source",
        "path": "/tmp/sing-box/rulesets/main-telegram-ruleset.json"
      },
      {
        "type": "local",
        "tag": "main-tiktok-ruleset",
        "format": "source",
        "path": "/tmp/sing-box/rulesets/main-tiktok-ruleset.json"
      }
    ],
    "final": "direct-out",
    "auto_detect_interface": true,
    "default_domain_resolver": "dns-server"
  },
  "services": [],
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "/tmp/sing-box/cache.db",
      "store_fakeip": true
    },
    "clash_api": {
      "external_controller": "192.168.23.1:9090"
    }
  }
}
